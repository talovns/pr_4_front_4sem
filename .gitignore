# Зависимости (самые тяжелые папки, их нельзя пушить)
node_modules/
jspm_packages/

# Скомпилированные файлы и билды
dist/
build/
.next/
out/

# Логи и временные файлы
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# Файлы окружения (где лежат секретные ключи и пароли)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Настройки редакторов (VS Code, WebStorm)
.vscode/
.idea/
*.swp
*.swo

# Системные файлы (особенно от macOS)
.DS_Store
Thumbs.db

# Файлы SASS (если они создают кэш)
.sass-cache/
*.css.map